{
  "manifest_version": 3,
  "name": "HAAI Recorder",
  "version": "0.1.0",
  "description": "Local-first AI interaction evidence recorder adapter.",
  "permissions": [
    "activeTab",
    "scripting",
    "storage",
    "clipboardWrite"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "browser_specific_settings": {
    "gecko": {
      "id": "haai-recorder@scrappyhub.local",
      "strict_min_version": "109.0"
    }
  },
  "background": {
    "scripts": [
      "src/background.js"
    ]
  },
  "content_scripts": [
    {
      "matches": [
        "<all_urls>"
      ],
      "js": [
        "src/content_script.js"
      ],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_popup": "src/popup.html",
    "default_title": "HAAI Recorder"
  }
}
